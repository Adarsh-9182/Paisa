# Postgres. Use the bundled docker-compose, or any Postgres URL (Neon/Supabase/RDS).
DATABASE_URL="postgresql://paisa:paisa@localhost:5432/paisa?schema=public"

# 32+ char secret used to sign session JWTs. Generate: openssl rand -base64 48
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# OPTIONAL. Without it the agent narrates with deterministic templates (still works).
# With it, the same grounded numbers get polished into natural English/Hinglish.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-3-5-haiku-20241022"
